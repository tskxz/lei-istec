<Window x:Class="Demo2022189.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo2022189"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <Grid>

                <Label Content="Tarefa:" HorizontalAlignment="Left" Margin="39,15,0,0" VerticalAlignment="Top" Width="60"/>
                <TextBox  x:Name="txtNome" HorizontalAlignment="Left" Height="24" Margin="148,16,0,0" Text="" VerticalAlignment="Top" Width="269"/>
                <Label Content="Notas:" HorizontalAlignment="Left" Margin="39,49,0,0" VerticalAlignment="Top"/>
                <TextBox  x:Name="txtNotas" HorizontalAlignment="Left" Height="24" Margin="148,51,0,0" Text="" VerticalAlignment="Top" Width="269"/>
                <Label Content="Duração:" HorizontalAlignment="Left" Margin="26,87,0,0" VerticalAlignment="Top"/>
                <TextBox x:Name="txtDuracao" HorizontalAlignment="Left" Height="24" Margin="148,87,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="51"/>
                <Label Content="Minutos" HorizontalAlignment="Left" Margin="216,87,0,0" VerticalAlignment="Top"/>
                <Label Content="Concluida:" HorizontalAlignment="Left" Margin="18,122,0,0" VerticalAlignment="Top"/>
                <CheckBox x:Name="chkConcluida" Content="" HorizontalAlignment="Left" Margin="148,128,0,0" VerticalAlignment="Top"/>
                <Button x:Name="btnSair" Content="Sair" Click="btnSair_Click" HorizontalAlignment="Left" Margin="667,128,0,0" VerticalAlignment="Top" Width="109" Height="32"/>
                <Button x:Name="btnGravar" Click="btnGravar_Click" Content="Criar" HorizontalAlignment="Left" Margin="667,51,0,0" VerticalAlignment="Top" Width="109"/>
                <Button x:Name="btnCancelar" Click="btnCancelar_Click" IsEnabled="False" Content="Cancelar" HorizontalAlignment="Left" Margin="667,15,0,129" Width="109"/>
                <Button x:Name="btnApagar" Click="btnApagar_Click" Content="Apagar" Visibility="Hidden" HorizontalAlignment="Left" Margin="667,93,0,0" VerticalAlignment="Top" Width="109"/>
                <Label Content="Custo" HorizontalAlignment="Left" Margin="282,85,0,0" VerticalAlignment="Top"/>
                <TextBox x:Name="txtCusto" HorizontalAlignment="Left" Height="24" Margin="327,87,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="51"/>
            </Grid>
            <Separator Height="10"/>
            <ListView x:Name="vidroPlacard" Height="200" SelectionChanged="vidroPlacard_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn 
                                Width="200" 
                                Header="Tarefa"
                                DisplayMemberBinding="{Binding Designacao}"/>
                        <GridViewColumn 
                                Width="200" 
                                Header="Anotações"
                                DisplayMemberBinding="{Binding Descricao}"/>
                        <GridViewColumn 
                                Width="100" 
                                Header="Duração"
                                DisplayMemberBinding="{Binding Custo}"/>
                        <GridViewColumn 
        Width="100" 
        Header="Duração"
        DisplayMemberBinding="{Binding Duracao}"/>
                        <GridViewColumn 
                                Width="50" 
                                Header="Estado"
                                DisplayMemberBinding="{Binding Concluida}"/>
                    </GridView>
                </ListView.View>
            </ListView>
            <Separator Height="10"/>
            <Label x:Name="lblTotalizador" Content="#" Width="700"/>
        </StackPanel>
    </Grid>
</Window>
